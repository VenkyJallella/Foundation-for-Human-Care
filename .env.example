# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database — leave blank to use SQLite (local dev). For PostgreSQL set:
# DATABASE_URL=postgres://user:password@localhost:5432/fhc
DATABASE_URL=

# Razorpay (get test keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=

# Email — contact-form messages are emailed to CONTACT_NOTIFICATION_EMAIL.
# Fill EMAIL_HOST_USER + EMAIL_HOST_PASSWORD (a Gmail App Password) to send for real;
# otherwise emails are printed to the console.
DEFAULT_FROM_EMAIL=Foundation for Human Care <no-reply@fhc.org>
CONTACT_NOTIFICATION_EMAIL=jallellavenky42@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
